# ── Token service ──────────────────────────────────────────────────────────
# URL of the centralised Zoho token service (must be running).
ZOHO_TOKEN_SERVICE_URL=http://127.0.0.1:8000/v1/token

# ── Zoho Desk API ─────────────────────────────────────────────────────────
# Base URL for the Zoho Desk REST API.
ZOHO_DESK_BASE=https://desk.zoho.com

# (Required) Organisation ID — sent as the 'orgId' header on every API call.
ZOHO_DESK_ORG_ID=

# (Optional) Fallback department ID used when the request does not supply one.
ZOHO_DESK_DEFAULT_DEPARTMENT_ID=

# ── Product map ───────────────────────────────────────────────────────────
# Comma-separated "name:id" pairs. Looked up before hitting the Zoho API.
# New products discovered at runtime are auto-appended to this value.
PRODUCT_MAP="Code Stroke Alert:1166045000001146278,Amendments:1166045000001146306,IT / Systems Issues:1166045000001146320,General:1166045000001146334,Critical Finding:1166045000001745494,NM Studies:1166045000001702243,Password Reset:1166045000003631101,Unlock Account:1166045000003631115,Account Creation:1166045000003837199,SUPER STAT:1166045000005037001,Onboarding:1166045000005172354,Patient Merge:1166045000006144025,RRO:1166045000006713586,Centricity:1166045000000603163,Reading Requests:1166045000001146264,Consults & Physician Connection:1166045000001146292"

# ── HTTP ──────────────────────────────────────────────────────────────────
# Timeout in seconds for outgoing HTTP requests. Must be > 0.
HTTP_TIMEOUT_SECONDS=30

# ── Logging ───────────────────────────────────────────────────────────────
# Python log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Log output format: 'json' for structured JSON lines, 'text' for human-readable.
LOG_FORMAT=json
